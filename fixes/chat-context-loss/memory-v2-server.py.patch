+def _fetch_context_text():
+    """Call the local memory MCP server (jsonrpc, port 3456) to get_context.
+    Returns plain text or "" on failure. Used to seed first-turn system prompt."""
+    payload = json.dumps({
+        "jsonrpc": "2.0", "id": 1,
+        "method": "tools/call",
+        "params": {"name": "get_context", "arguments": {}},
+    }).encode("utf-8")
+    # Token-gated endpoint — same TOKEN baked into /root/mcp-server/server.py
+    req = urllib.request.Request(
+        "http://127.0.0.1:3456/3631e4d7155a4255b9aeb5bdb89a46b4",
+        data=payload,
+        headers={"Content-Type": "application/json"},
+    )
+    try:
+        with urllib.request.urlopen(req, timeout=8) as resp:
+            d = json.loads(resp.read())
+        content = d.get("result", {}).get("content", [])
+        if content and isinstance(content, list):
+            return content[0].get("text", "") or ""
+    except Exception as e:
+        print(f"[chat] _fetch_context_text failed: {e}")
+    return ""
+
